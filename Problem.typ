// ==================== 全局设置 ====================
#set page(
  paper: "a4",
  margin: (left: 2.5cm, right: 2.5cm, top: 2.5cm, bottom: 2.5cm),
  numbering: "1",
  number-align: center
)

#set text(font: ("New Computer Modern", "SimSun"), size: 12pt)

// ==================== 自定义样式 ====================
// 标题样式
#let 主标题(title) = align(center, text(weight: "bold", size: 20pt, title))

// 章节样式（对应 LaTeX 的 section）
#let 题目章节(title) = [
  #v(12pt)
  #set text(weight: "bold", size: 16pt)
  #line(length: 100%)
  #align(center, title)
  #line(length: 100%)
  #v(8pt)
]

// 子章节样式（对应 LaTeX 的 subsection）
#let 子章节(title) = [
  #v(8pt)
  #set text(weight: "bold", size: 13pt)
  title
  #v(4pt)
]

// 代码块样式（用于展示样例）
#let 代码块(content) = [
  #set text(font: ("DejaVu Sans Mono", "Fira Code", "Consolas"), size: 10pt)
  #rect(
    inset: 8pt,
    fill: rgb("#f5f5f5"),
    radius: 4pt,
    stroke: rgb("#dddddd"),
    content
  )
]

// 内联代码样式
#let 内联代码(content) = {
  [#set text(font: ("DejaVu Sans Mono", "Fira Code", "Consolas"), size: 11pt)
  #content]
}

// 特殊强调样式（对应 \CJKdotbf）
#let 强调(content) = text(weight: "bold", content)

// ==================== 文档变量 ====================
#let 文档标题 = "NOIP模拟赛"
#let 文档作者 = "Gold & yyy"
#let 比赛日期 = "08:00~11:40"

// ==================== 封面 ====================
#align(center)[
  #v(48pt)
  #text(weight: "bold", size: 28pt, 文档标题)
  #v(16pt)
  #text(文档作者)
  #v(16pt)
  #text(比赛日期)
]
#v(32pt)

// ==================== 题目信息表格 ====================
#let 内联代码1 = 内联代码
#table(
  columns: (auto, auto, auto, auto, auto),
  stroke: (left: none, right: none),
